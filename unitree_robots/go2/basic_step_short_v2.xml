<mujoco model="go2 scene">
  <include file="go2.xml" />

  <statistic center="0 0 0.1" extent="0.8" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="-130" elevation="-20" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
    <!-- v2 (basic_step_short_v2): basic_step_short with extended box1 so the
         robot has room to stabilize into a stable trot ON box1 BEFORE the
         descent edge. v1 had box1 halfsize_x=0.3 → front feet (hip offset
         x≈+0.2) reached the edge after only ~0.33s of forward (less than one
         trot period 0.6s) → robot descended mid-first-swing, contributing
         to initial-transient instability.

         v2: box1 halfsize_x=0.6 → edge at x=+0.6 → front feet reach edge
         after ~1.33s of forward (≈2.2 trot cycles) → ~2 stable trot cycles
         on box1 before descent. box2 shifted (pos.x 1.3 → 1.6) so it stays
         adjacent to the new box1 edge. Heights and y-extent unchanged. -->
    <geom pos="0.0 0.0 0.1" type="box" size="0.6 1.0 0.1" quat="1.0 0.0 0.0 0.0" />
    <geom pos="1.6 0.0 0.05" type="box" size="1.0 1.0 0.05" quat="1.0 0.0 0.0 0.0" />
  </worldbody>
</mujoco>
